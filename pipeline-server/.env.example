# pipeline-server — optional (no paid STT keys)
PIPELINE_PORT=3002
PIPELINE_DATA_DIR=

# yt-dlp: auto-detects `py -m yt_dlp` if yt-dlp.exe is not on PATH (Windows default)
# YT_DLP_PATH=C:\Tools\yt-dlp.exe
# PYTHON=py

# Optional: only if you explicitly enable YouTube Data API upload + supply OAuth token from UI
# ENABLE_YOUTUBE_DATA_API_UPLOAD=false

# Local faster-whisper (optional fallback when YT has no English auto-subs)
# LOCAL_WHISPER_MODEL=base
# LOCAL_WHISPER_DEVICE=cpu
# LOCAL_WHISPER_COMPUTE=int8
