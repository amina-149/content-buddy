# Content Buddy — backend. Copy to `.env` in this folder.
# Defaults align with docker-compose.yml (postgres + redis service names / credentials).

NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# From host machine (backend running locally, DB in Docker on published ports)
DATABASE_URL=postgresql://omnisolve_user:omnisolve_secure_password_change_in_prod@localhost:5432/omnisolve_db
SHADOW_DATABASE_URL=postgresql://omnisolve_user:omnisolve_secure_password_change_in_prod@localhost:5432/omnisolve_shadow_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=omnisolve_redis_password_change_in_prod
REDIS_DB=0

JWT_SECRET=change_this_to_32_character_random_string_in_production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OAuth — replace with real app credentials for platform tests
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CALLBACK_URL=http://localhost:3001/auth/youtube/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:3001/auth/instagram/callback

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_CALLBACK_URL=http://localhost:3001/auth/tiktok/callback

STORAGE_PATH=./storage/videos
TEMP_PATH=./storage/temp

CAPTION_WORKER_ENABLED=true
RENDER_WORKER_ENABLED=true
PUBLISH_WORKER_ENABLED=true

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_DEVICE_INDEX=0
FFMPEG_PATH=ffmpeg

LOG_LEVEL=debug
